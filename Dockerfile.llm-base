FROM node:22-bookworm-slim AS node

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HOME=/home/dev \
    UV_CACHE_DIR=/var/cache/uv \
    UV_LINK_MODE=copy \
    UV_PROJECT_ENVIRONMENT=/var/cache/uv/project-env \
    KELPIE_TEMPLATE_DIR=/opt/kelpie \
    KELPIE_SCRIPT_DIR=/opt/kelpie/scripts

COPY --from=ghcr.io/astral-sh/uv:0.8.22 /uv /uvx /bin/
COPY --from=node /usr/local/ /usr/local/
COPY llm-entrypoint.sh /usr/local/bin/llm-entrypoint.sh
COPY AGENTS.md ${KELPIE_TEMPLATE_DIR}/AGENTS.md
COPY prompts/ ${KELPIE_TEMPLATE_DIR}/prompts/
COPY skills/ ${KELPIE_TEMPLATE_DIR}/skills/
COPY examples/ ${KELPIE_TEMPLATE_DIR}/examples/
COPY scripts/ ${KELPIE_SCRIPT_DIR}/

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates git gh curl wget ripgrep less procps openssh-client \
    && npm install -g @google/gemini-cli @openai/codex @github/copilot \
    && chmod +x /usr/local/bin/llm-entrypoint.sh \
    && find "${KELPIE_SCRIPT_DIR}" -maxdepth 1 -type f -exec chmod 0755 {} + \
    && find "${KELPIE_SCRIPT_DIR}" -maxdepth 1 -type f -exec ln -sf {} /usr/local/bin/ \; \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p \
        /workspace \
        /home/dev \
        /var/cache/uv \
        /var/cache/uv/project-env \
    && chown -R 1000:1000 /workspace /home/dev \
    && chmod 1777 /var/cache/uv /var/cache/uv/project-env

WORKDIR /workspace

CMD ["sh"]
